{
  "port": 4499,
  "staleDays": 60,
  "minCacheMB": 100,
  "minAppDataMB": 500,
  "projectRoots": [
    "~/code",
    "~/projects"
  ],
  "extraDirs": [
    "~/work",
    "~/experiments"
  ],
  "protected": [
    "~/Library/Application Support/Claude",
    "~/.claude",
    "~/.claude-mem"
  ],
  "extraCaches": [
    "~/Library/Application Support/Claude/vm_bundles",
    "~/Library/Application Support/Claude/Cache",
    "~/Library/Application Support/Claude/Code Cache"
  ],
  "remote": {
    "enabled": false,
    "host": "",
    "user": "",
    "path": "/mnt/external/mac-archive",
    "sshKey": "",
    "sshPort": 22,
    "note": "host = Tailscale device name. sshKey/sshPort optional: leave sshKey blank to use the SSH agent; set sshPort only if the remote is not on 22."
  }
}
